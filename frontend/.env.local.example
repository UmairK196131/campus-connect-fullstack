# The Flask backend's URL — used directly by the browser for the Socket.IO
# connection (this one can NOT go through the Next.js rewrite proxy, since
# WebSocket upgrades don't reliably pass through it).
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Used server-side only, by next.config.js, to proxy /api/* calls to Flask.
BACKEND_URL=http://localhost:5000
